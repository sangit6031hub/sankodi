<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.sankodi" name="SanKodi Video Browser" version="1.0.1" provider-name="San">
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">Browse and play videos from TamilGun and other websites</summary>
    <description lang="en_GB">A Kodi plugin to browse and stream videos from multiple websites including TamilGun. Features include pagination support, thumbnail browsing, and configurable website URLs.</description>
    <platform>all</platform>
    <license>GPL-3.0</license>
    <website>https://github.com/sangit6031hub/sankodi</website>
    <source>https://github.com/sangit6031hub/sankodi</source>
    <assets>
      <icon>resources/icon.png</icon>
      <fanart>resources/fanart.jpg</fanart>
    </assets>
  </extension>
</addon>